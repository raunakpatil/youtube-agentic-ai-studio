# YouTube AI Agent Studio — Environment Variables
# Copy this file to .env and fill in your keys.
# The app reads these automatically (config.py uses os.getenv).

GEMINI_API_KEY=your_gemini_api_key_here
PEXELS_API_KEY=your_pexels_api_key_here

# Optional — only needed if using ElevenLabs TTS instead of Edge TTS
ELEVENLABS_API_KEY=your_elevenlabs_key_here
